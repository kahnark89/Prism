<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Vision pipeline (Doc 3.0 §2: camera -> vision -> recognition, on-device, Hard Line 3) -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="true" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />

    <!-- Conversation input (MicHAL redesign — see hal/HardwareAbstractionLayer.kt) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Composable haptic waveforms — Awakening Beats 2 & 3 (Doc 2.3 §3) -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Smart-brain calls + zero-knowledge relay sync (Doc 3.0 §3.3); gracefully degrades offline -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Local-first peer-to-peer sync with the paired Parent Suite device (Doc 3.0 §3.3) -->
    <uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES" />

    <application
        android:name=".PrismCompanionApp"
        android:allowBackup="false"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:theme="@style/Theme.Prism.Companion"
        android:supportsRtl="true">

        <!--
          lockTaskMode="if_whitelisted": the software replacement for "sealed
          enclosure, no detachable parts" (Doc 3.0 §4 translation table — "OS-level
          guided-access/kiosk lock... Mechanism: software lock replaces molded
          plastic"). The parent's setup flow enrolls this app as the device owner's
          lock-task package; once locked, the only way out is the parent's gate.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Prism.Companion"
            android:lockTaskMode="if_whitelisted"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
