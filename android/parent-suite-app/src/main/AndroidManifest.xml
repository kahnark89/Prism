<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Sync with Companion over local network (Doc 3.0 §3.3) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Local-first peer-to-peer pairing + sync (Doc 3.0 §3.2–3.3) -->
    <uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES" />

    <!--
      No CAMERA permission here: Doc 3.0 §3.2 step 1 assigns roles explicitly —
      Parent Suite DISPLAYS the QR code; Companion SCANS it. The camera stays on
      the child-facing device, not the parent's phone.
    -->

    <application
        android:name=".PrismParentApp"
        android:allowBackup="false"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:theme="@style/Theme.Prism.Parent"
        android:supportsRtl="true">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Prism.Parent"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
